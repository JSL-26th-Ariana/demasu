# ====================================================
# application.properties.example
# 이 파일을 복사해서 application.properties로 만들고
# 본인 환경에 맞게 값을 채워넣으세요!
# cp application.properties.example application.properties
# ====================================================

# Application Basic Setting
spring.application.name=jsl26tp

# Setting Server PORT
server.port=8090

# Connection Setting Of MySQL
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
spring.datasource.url=jdbc:mysql://localhost:3306/jsl26tp?serverTimezone=UTC
spring.datasource.username=여기에_MySQL_유저명
spring.datasource.password=여기에_MySQL_비밀번호

# Setting MyBatis
mybatis.mapper-locations=classpath:mapper/**/*.xml
mybatis.type-aliases-package=com.jsl26tp.jsl26tp.auth.domain,com.jsl26tp.jsl26tp.toilet.domain,com.jsl26tp.jsl26tp.review.domain,com.jsl26tp.jsl26tp.report.domain,com.jsl26tp.jsl26tp.inquiry.domain
mybatis.configuration.map-underscore-to-camel-case=true

# Setting Thymeleaf
spring.thymeleaf.cache=false

# Setting Encoding
server.servlet.encoding.charset=UTF-8
server.servlet.encoding.enabled=true
server.servlet.encoding.force=true

# Naver Maps API
naver.maps.client-id=여기에_네이버지도_API_키

# File Upload Path
app.upload.path=${user.home}/jsl26tp-uploads/
file.upload-root=${app.upload.path}
file.path.profile=${file.upload-root}profile/
file.path.review=${file.upload-root}review/

# File Limit
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=20MB
